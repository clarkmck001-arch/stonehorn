# Copy this file to ".env" and fill real values.

HOST=127.0.0.1
PORT=5500

# Admin review login password
STONEHORN_ADMIN_EMAIL=admin@stonehorn.local
STONEHORN_ADMIN_PASSWORD=stonehorn-admin

# Stripe API keys (required for live checkout)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional order confirmation email via Resend
RESEND_API_KEY=re_replace_me
ORDER_EMAIL_FROM=Stonehorn <orders@yourdomain.com>
ORDER_EMAIL_REPLY_TO=support@yourdomain.com
# Optional low stock alert recipient (defaults to STONEHORN_ADMIN_EMAIL)
LOW_STOCK_ALERT_TO=alerts@yourdomain.com

# Data persistence mode: "sqlite" (default), "json", or "postgres"
STONEHORN_STORAGE=sqlite
# Max approved bragging board posts to keep (oldest auto-deleted)
BRAGGING_BOARD_MAX_APPROVED=60
# For Postgres mode:
# STONEHORN_STORAGE=postgres
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DATABASE_SSL=true
# Optional absolute paths (recommended for Render persistent disk)
# STONEHORN_DATA_DIR=/var/data/stonehorn/data
# STONEHORN_UPLOAD_DIR=/var/data/stonehorn/uploads
